{
  "name": "mvext",
  "version": "0.0.1",
  "private": true,
  "description": "Make VSCode Extension",
  "keywords": [
    "extension",
    "vscode"
  ],
  "license": "MIT",
  "author": "Ming Chen <cm.email@qq.com> (https://github.com/xingqingxyz)",
  "type": "module",
  "scripts": {
    "extension:install": "pnpm run -r extension:install",
    "extension:publish": "pnpm run -C ./extensions/vue extension:publish && pnpm -r --filter !vue exec vsce publish",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@types/emscripten": "^1.41.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@types/which": "^3.0.4",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "jsonc-parser": "^3.3.1",
    "mocha": "^11.7.5",
    "os-browserify": "^0.3.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "rolldown": "1.0.0-rc.17",
    "simple-git-hooks": "^2.13.1",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3",
    "which": "^6.0.1"
  },
  "simple-git-hooks": {
    "pre-commit": "oxlint --type-aware --type-check --fix && oxfmt && git add . && pnpm run -r --if-present test"
  },
  "packageManager": "pnpm@10.33.2"
}
