{
  "name": "vincode",
  "displayName": "Morden Vim in VSCode",
  "version": "0.3.0",
  "private": true,
  "description": "Bring benefits from Vim to VSCode.",
  "categories": [
    "Keymaps"
  ],
  "bugs": {
    "url": "https://github.com/xingqingxyz/vincode/issues"
  },
  "author": "Ming Chen <cm.email@qq.com> (https://github.com/xingqingxyz)",
  "repository": {
    "type": "git",
    "url": "https://github.com/xingqingxyz/vincode"
  },
  "publisher": "xingqingxyz",
  "type": "module",
  "main": "./dist/extension.js",
  "browser": "./dist/extension.cjs",
  "scripts": {
    "extension:install": "vsce pack -o vincode.vsix && code --install-extension vincode.vsix",
    "lint": "concurrently \"tsc --noEmit\" \"oxlint --type-aware --fix\"",
    "pretest": "rolldown -c --environment NODE_ENV:test",
    "vscode:prepublish": "concurrently \"rolldown -c --environment NODE_ENV:production\" \"rolldown -c --environment NODE_ENV:production,PLATFORM:web\"",
    "watch-web": "rolldown -c -w --environment PLATFORM:web",
    "watch": "rolldown -c -w"
  },
  "contributes": {
    "commands": [
      {
        "command": "vincode.toggleVimMode",
        "title": "Toggle Vim Mode"
      },
      {
        "command": "vincode.toggleLessMode",
        "title": "Toggle Less Mode"
      },
      {
        "command": "vincode.repeatPrevLineChar",
        "title": "Repeat Prev Line Char"
      },
      {
        "command": "vincode.repeatNextLineChar",
        "title": "Repeat Next Line Char"
      },
      {
        "command": "vincode.cursorHalfPageDown",
        "title": "Cursor Half Page Down"
      },
      {
        "command": "vincode.cursorHalfPageUp",
        "title": "Cursor Half Page Up"
      },
      {
        "command": "vincode.manKeyword",
        "title": "Man Keyword"
      },
      {
        "command": "vincode.leapToWordStart",
        "title": "Leap to Word Start"
      },
      {
        "command": "vincode.cancelLeap",
        "title": "Cancel Leap"
      }
    ],
    "keybindings": [
      {
        "command": "vincode.toggleVimMode",
        "key": "shift+space",
        "when": "editorTextFocus"
      },
      {
        "command": "vincode.toggleLessMode",
        "key": "ctrl+alt+space",
        "when": "editorTextFocus"
      },
      {
        "args": "h",
        "command": "vincode.nextSequence",
        "key": "backspace",
        "when": "editorTextFocus && vincode.mode != insert"
      },
      {
        "args": "l",
        "command": "vincode.nextSequence",
        "key": "tab",
        "when": "editorTextFocus && vincode.mode != insert"
      },
      {
        "command": "vincode.repeatPrevLineChar",
        "key": "ctrl+y",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "vincode.repeatNextLineChar",
        "key": "ctrl+e",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "args": false,
        "command": "vincode.toggleLessMode",
        "key": "q",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollPageDown",
        "key": "f",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollPageDown",
        "key": "space",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollPageUp",
        "key": "b",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollPageUp",
        "key": "shift+space",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "vincode.cursorHalfPageDown",
        "key": "d",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "vincode.cursorHalfPageUp",
        "key": "u",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollLineDown",
        "key": "e",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "scrollLineUp",
        "key": "y",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorDown",
        "key": "j",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorUp",
        "key": "k",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorLeft",
        "key": "h",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorRight",
        "key": "l",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorTop",
        "key": "g",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "cursorBottom",
        "key": "shift+g",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "vincode.manKeyword",
        "key": "shift+k",
        "when": "editorTextFocus && vincode.mode == less"
      },
      {
        "command": "vincode.leapToWordStart",
        "key": "alt+space",
        "when": "editorTextFocus && vincode.mode != leap"
      },
      {
        "command": "vincode.cancelLeap",
        "key": "escape",
        "when": "editorTextFocus && vincode.mode == leap"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  }
}
