{
  "name": "toml",
  "displayName": "TOML",
  "version": "0.3.0",
  "private": true,
  "description": "TOML language supports based on taplo.",
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "bugs": {
    "url": "https://github.com/xingqingxyz/toml/issues"
  },
  "license": "MIT",
  "author": "Ming Chen <cm.email@qq.com> (https://github.com/xingqingxyz)",
  "repository": {
    "type": "git",
    "url": "https://github.com/xingqingxyz/toml"
  },
  "publisher": "xingqingxyz",
  "type": "module",
  "main": "./dist/extension.js",
  "browser": "./dist/extension.cjs",
  "scripts": {
    "extension:install": "vsce pack -o toml.vsix && code --install-extension toml.vsix",
    "lint": "concurrently \"tsc --noEmit\" \"oxlint --type-aware --fix\"",
    "pretest": "rolldown -c --environment NODE_ENV:test",
    "vscode:prepublish": "concurrently \"rolldown -c --environment NODE_ENV:production\" \"rolldown -c --environment NODE_ENV:production,PLATFORM:web\"",
    "watch-web": "rolldown -c -w --environment PLATFORM:web",
    "watch": "rolldown -c -w"
  },
  "devDependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "commands": [
      {
        "category": "TOML",
        "command": "toml.selectSchema",
        "enablement": "editorLangId == toml",
        "title": "Select Schema"
      },
      {
        "category": "TOML",
        "command": "toml.copyAsJson",
        "enablement": "editorHasSelection",
        "title": "Copy as JSON"
      },
      {
        "category": "TOML",
        "command": "toml.copyAsToml",
        "enablement": "editorHasSelection",
        "title": "Copy as TOML"
      },
      {
        "category": "TOML",
        "command": "toml.pasteAsJson",
        "title": "Paste as JSON"
      },
      {
        "category": "TOML",
        "command": "toml.pasteAsToml",
        "title": "Paste as TOML"
      }
    ],
    "configuration": {
      "properties": {
        "toml.taplo.extraArgs": {
          "default": [],
          "description": "Additional arguments for Taplo.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "toml.taplo.path": {
          "default": "taplo",
          "description": "An absolute path to the `taplo` executable.",
          "type": "string"
        }
      },
      "title": "TOML"
    },
    "grammars": [
      {
        "language": "toml",
        "path": "./syntax/toml.tmLanguage.json",
        "scopeName": "source.toml"
      },
      {
        "injectTo": [
          "text.html.markdown"
        ],
        "path": "./syntax/toml.frontmatter.tmLanguage.json",
        "scopeName": "markdown.toml.frontmatter.codeblock"
      },
      {
        "embeddedLanguages": {
          "meta.embedded.block.toml": "toml"
        },
        "injectTo": [
          "text.html.markdown"
        ],
        "path": "./syntax/toml.markdown.tmLanguage.json",
        "scopeName": "markdown.toml.codeblock"
      }
    ],
    "languages": [
      {
        "aliases": [
          "TOML"
        ],
        "configuration": "./language-configuration.json",
        "extensions": [
          ".toml"
        ],
        "filenames": [
          "Cargo.lock",
          "uv.lock"
        ],
        "id": "toml"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "tomlArrayKey": [
            "support.type.property-name.array.toml"
          ],
          "tomlTableKey": [
            "support.type.property-name.table.toml"
          ]
        }
      }
    ],
    "semanticTokenTypes": [
      {
        "description": "Array keys.",
        "id": "tomlArrayKey",
        "superType": "variable"
      },
      {
        "description": "Inline table keys.",
        "id": "tomlTableKey",
        "superType": "variable"
      }
    ]
  },
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.116.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  }
}
