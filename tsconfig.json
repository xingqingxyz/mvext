{
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["node", "mocha", "emscripten"],
    "module": "ESNext",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext"
  }
}
